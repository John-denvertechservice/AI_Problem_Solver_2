{
  "manifest_version": 3,
  "name": "AI Problem Solver",
  "version": "2.0.0",
  "description": "AI-powered assistant for solving math, logic, and coding problems with OpenAI and Claude",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "contextMenus"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "vendor/marked.min.js",
        "vendor/purify.min.js",
        "vendor/highlight.min.js",
        "vendor/katex.min.js",
        "vendor/katex.auto-render.min.js",
        "content.js"
      ],
      "css": [
        "vendor/katex.min.css",
        "vendor/highlight-theme.css",
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["fonts/*.woff2", "vendor/fonts/*.woff2"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "options.html",
  "commands": {
    "analyze-selection": {
      "suggested_key": {
        "default": "Alt+Shift+A",
        "mac": "Alt+Shift+A"
      },
      "description": "Analyze selected text or image"
    },
    "welcome-bubble": {
      "suggested_key": {
        "default": "Alt+Shift+K",
        "mac": "Alt+Shift+K"
      },
      "description": "Open Welcome Bubble"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
